{
  "description": "Regex patterns for credential and secret detection",
  "patterns": {
    "api_key": "(?i)(api[_-]?key|apikey)\\s*[=:]\\s*['\"]?([a-zA-Z0-9_\\-]{20,})['\"]?",
    "bearer_token": "(?i)bearer\\s+[a-zA-Z0-9_\\-\\.]{20,}",
    "password": "(?i)(password|passwd|pwd)\\s*[=:]\\s*['\"]?(\\S{6,})['\"]?",
    "secret_key": "(?i)(secret[_-]?key|client[_-]?secret)\\s*[=:]\\s*['\"]?([a-zA-Z0-9_\\-]{16,})['\"]?",
    "aws_key": "(?i)AKIA[0-9A-Z]{16}",
    "private_key": "-----BEGIN\\s+(RSA\\s+)?PRIVATE\\s+KEY-----",
    "internal_url": "https?://(?:internal|intranet|corp|private)[.\\-][a-zA-Z0-9\\-]+\\.[a-zA-Z]{2,}(?:/\\S*)?",
    "connection_string": "(?i)(mongodb|postgresql|mysql|redis|amqp)://\\S+",
    "jwt_token": "eyJ[a-zA-Z0-9_-]+\\.eyJ[a-zA-Z0-9_-]+\\.[a-zA-Z0-9_-]+",
    "github_token": "gh[ps]_[a-zA-Z0-9]{36,}",
    "slack_token": "xox[baprs]-[a-zA-Z0-9\\-]+"
  }
}
