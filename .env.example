# Phantom App Environment Variables
# Copy this file to .env and fill in your values

# Hugging Face — Developer 1 (intent classification, risky intent detection)
HUGGINGFACE_API_KEY=hf_your_token_here

# CokeGPT Internal API — Developer 2
COKEGPT_API_KEY=your_cokegpt_api_key_here

# Supabase — Developer 3 (database, logging, analytics)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_key_here

# Slack/Teams Webhook — Developer 3 (notifications)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx

# Application Settings
APP_ENV=development
APP_PORT=8000
APP_HOST=0.0.0.0
DEBUG=True

# Deployment Mode: SHADOW or FULL_ENFORCEMENT
DEPLOYMENT_MODE=SHADOW

# Default Policy Mode: STRICT, BALANCED, or FAST
DEFAULT_POLICY_MODE=BALANCED
